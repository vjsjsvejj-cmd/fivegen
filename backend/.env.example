# ========================================
# Five Gen 2.4.1 后端配置文件
# 复制此文件为 .env 并填入实际配置
# ========================================

# 服务器配置
# 局域网访问请保持 HOST=0.0.0.0
HOST=0.0.0.0
PORT=8000

# CORS 配置
# 局域网访问说明：后端已支持动态 CORS 校验，会自动允许本机所有 IP 的请求
# 如果需要限制特定来源，请列出完整 URL（逗号分隔）
# ⚠️ 安全警告：生产环境切勿使用 *，应明确指定允许的域名
# 允许所有来源（仅限开发环境）：ALLOWED_ORIGINS=*
# 指定来源：ALLOWED_ORIGINS=http://localhost:3000,http://192.168.1.100:3000
ALLOWED_ORIGINS=http://localhost:3000

# ========================================
# 火山引擎 API 配置
# ========================================
VOLCENGINE_API_KEY=your-volcengine-api-key-here
VOLCENGINE_IMAGE_MODEL=doubao-seedream-5-0-260128
VOLCENGINE_VIDEO_MODEL=doubao-seedance-2-0-260128
IMAGE_API_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
VIDEO_API_URL=https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks

# ========================================
# GRSAI API 配置
# ========================================
GRSAI_API_KEY=your-grsai-api-key-here

# ========================================
# 逆向解析配置
# ========================================
INVERSION_API_KEY=your-inversion-api-key-here
INVERSION_MODEL=doubao-seed-2-0-lite-260215

# ========================================
# 智谱AI 声音克隆配置
# ========================================
GLM_API_KEY=your-glm-api-key-here

# ========================================
# 数字人配置（待定API）
# ========================================
DIGITAL_HUMAN_API_KEY=
DIGITAL_HUMAN_BASE_URL=
DIGITAL_HUMAN_MODEL=

# ========================================
# TOS 对象存储配置
# ========================================
TOS_ACCESS_KEY=your-tos-access-key-here
TOS_SECRET_KEY=your-tos-secret-key-here
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_REGION=cn-beijing
TOS_BUCKET=fivesd
