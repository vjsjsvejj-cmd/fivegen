# ========================================
# Five Gen 2.4 后端配置文件
# 复制此文件为 .env 并填入实际配置
# ========================================

# 服务器配置
HOST=0.0.0.0
PORT=8000

# CORS 配置
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ========================================
# 火山引擎 API 配置
# ========================================
VOLCENGINE_API_KEY=your-volcengine-api-key-here
VOLCENGINE_IMAGE_MODEL=doubao-seedream-5-0-260128
VOLCENGINE_VIDEO_MODEL=doubao-seedance-2-0-260128

# ========================================
# GRSAI API 配置
# ========================================
GRSAI_API_KEY=your-grsai-api-key-here

# ========================================
# TOS 对象存储配置
# ========================================
TOS_ACCESS_KEY=your-tos-access-key-here
TOS_SECRET_KEY=your-tos-secret-key-here
TOS_ENDPOINT=tos-cn-beijing.volces.com
TOS_REGION=cn-beijing
TOS_BUCKET=fivesd
